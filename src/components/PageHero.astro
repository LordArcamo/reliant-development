---
interface Props {
  eyebrow: string;
  title: string;
  lede: string;
  image: string;
  imageAlt: string;
}
const { eyebrow, title, lede, image, imageAlt } = Astro.props;
---

<section class="atmo border-b border-ink-900/10" data-no-reveal>
  <div class="mx-auto grid max-w-site items-center gap-10 px-5 pb-16 pt-32 lg:grid-cols-[1.15fr_0.85fr] lg:gap-14 lg:px-8 lg:pb-20 lg:pt-40">
    <div>
      <p class="eyebrow">{eyebrow}</p>
      <h1 class="display mt-4 text-[clamp(2.3rem,5.5vw,3.8rem)]" set:html={title} />
      <p class="mt-6 max-w-xl text-[1.08rem] leading-relaxed text-ink-700">{lede}</p>
    </div>
    <figure class="hidden md:block">
      <div class="card-shadow relative overflow-hidden border border-ink-900/10">
        <div class="absolute inset-x-0 top-0 z-10 h-[3px] bg-brand"></div>
        <img src={image} alt={imageAlt} class="aspect-[4/3] w-full object-cover" loading="eager" />
      </div>
    </figure>
  </div>
</section>

---
import { site } from '../data/site';

const states = [
  {
    abbr: 'NJ',
    name: 'New Jersey',
    detail: 'Home state. Every county, from Bergen to Cape May.',
  },
  {
    abbr: 'NY',
    name: 'New York',
    detail: 'Downstate, Long Island, Hudson Valley, and the NYC metro.',
  },
  {
    abbr: 'PA',
    name: 'Pennsylvania',
    detail: 'Eastern PA — the Philadelphia metro and the Lehigh Valley.',
  },
];
---

<section id="service-area" class="border-y border-ink-900/10 bg-paper-soft">
  <div class="mx-auto grid max-w-site gap-12 px-5 py-20 lg:grid-cols-12 lg:gap-16 lg:px-8 lg:py-28">
    <div class="lg:col-span-7">
      <p class="eyebrow">Service area</p>
      <h2 class="display mt-4 text-[clamp(1.9rem,4vw,2.9rem)]">
        Three states. <span class="text-brand-deep">Every county.</span>
      </h2>
      <p class="mt-6 max-w-prose text-[1.02rem] leading-relaxed text-ink-700">
        Reliant Construction is headquartered in {site.address.city}, {site.address.region}. Our
        crews mobilize daily across the NJ · NY · PA footprint — from Long Island to the Lehigh
        Valley, every county of New Jersey, and the Philadelphia and New York metros.
      </p>

      <div class="mt-10 space-y-px bg-ink-900/10">
        {
          states.map((s) => (
            <div class="grid grid-cols-12 items-baseline gap-4 bg-paper p-6 transition-colors hover:bg-[--band] sm:p-7">
              <div class="col-span-3 font-display text-[2.2rem] font-bold leading-none text-brand-bright sm:col-span-2 sm:text-[2.6rem]">
                {s.abbr}
              </div>
              <div class="col-span-9 font-display text-[1.1rem] font-bold sm:col-span-3">{s.name}</div>
              <div class="col-span-12 text-[0.92rem] leading-relaxed text-ink-700 sm:col-span-7">{s.detail}</div>
            </div>
          ))
        }
      </div>
    </div>

    <div class="lg:col-span-5">
      <div class="lg:sticky lg:top-32">
        <div class="card-shadow relative flex aspect-[4/5] items-center justify-center overflow-hidden border border-ink-900/10 bg-paper p-6 sm:p-8">
          <img
            src="/images/maps/tri-state.png"
            alt="Service area map showing New Jersey, New York, and Pennsylvania"
            loading="lazy"
            class="relative h-full w-full object-contain"
          />

          <!-- HQ marker + amber signal rings over South Plainfield -->
          <div class="pointer-events-none absolute" style="right: 27%; top: 66.5%;" aria-hidden="true">
            <span class="cov-ring absolute -translate-x-1/2 -translate-y-1/2 rounded-full border border-brand"></span>
            <span class="cov-ring cov-ring-d2 absolute -translate-x-1/2 -translate-y-1/2 rounded-full border border-brand"></span>
            <span class="cov-ring cov-ring-d3 absolute -translate-x-1/2 -translate-y-1/2 rounded-full border border-brand"></span>
            <span class="absolute flex h-9 w-9 -translate-x-1/2 -translate-y-1/2 items-center justify-center rounded-full bg-ink-900 shadow-[0_2px_8px_rgba(0,0,0,0.5)] ring-1 ring-ink-900/20">
              <img src="/images/logo-mark-amber.png" alt="" style="width: 22px; height: 22px; max-width: none;" />
            </span>
          </div>

          <div class="absolute right-5 top-5 text-right">
            <div class="font-mono text-[0.72rem] font-bold uppercase tracking-[0.18em] text-ink-900">Reliant HQ</div>
            <div class="font-mono text-[0.62rem] uppercase tracking-[0.14em] text-ink-700">
              {site.address.city}, {site.address.region} · Est. {site.founded}
            </div>
          </div>

          <div class="absolute bottom-4 left-5 right-5 flex items-center justify-between">
            <span class="font-mono text-[0.62rem] uppercase tracking-[0.22em] text-ink-700">
              Service area · {site.address.city}, {site.address.region}
            </span>
            <span class="font-mono text-[0.62rem] font-semibold uppercase tracking-[0.22em] text-ink-900">NJ · NY · PA</span>
          </div>
        </div>

        <div class="mt-6 grid grid-cols-2 gap-px bg-ink-900/10">
          <div class="bg-paper p-4">
            <div class="mb-1 font-mono text-[0.65rem] uppercase tracking-[0.18em] text-ink-500">HQ</div>
            <div class="text-[0.85rem] font-semibold text-ink-900">{site.address.street}</div>
            <div class="text-[0.78rem] text-ink-500">
              {site.address.city}, {site.address.region} {site.address.zip}
            </div>
          </div>
          <div class="bg-paper p-4">
            <div class="mb-1 font-mono text-[0.65rem] uppercase tracking-[0.18em] text-ink-500">Coverage</div>
            <div class="text-[0.85rem] font-semibold text-ink-900">NJ · NY · PA</div>
            <div class="text-[0.78rem] text-ink-500">Residential &amp; commercial</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes cov-ring-pulse {
    0% {
      transform: translate(-50%, -50%) scale(0.07);
      opacity: 0.75;
    }
    70% {
      opacity: 0.16;
    }
    100% {
      transform: translate(-50%, -50%) scale(1);
      opacity: 0;
    }
  }
  .cov-ring {
    width: 320px;
    height: 320px;
    opacity: 0;
    animation: cov-ring-pulse 4.2s ease-out infinite;
  }
  .cov-ring-d2 {
    animation-delay: 1.4s;
  }
  .cov-ring-d3 {
    animation-delay: 2.8s;
  }
  @media (prefers-reduced-motion: reduce) {
    .cov-ring {
      animation: none !important;
    }
  }
</style>

---
import { site, nav } from '../data/site';

const path = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header id="site-nav" class="nav-enter fixed inset-x-0 top-0 z-50">
  <!-- Scrolled backdrop: always present, fades in — no class-swap snap -->
  <div class="nav-bg pointer-events-none absolute inset-0 border-b border-ink-900/10 bg-paper/90 opacity-0 backdrop-blur-md"></div>

  <div class="relative mx-auto flex h-[72px] max-w-site items-center justify-between px-5 lg:px-8">
    <a href="/" class="group flex items-center gap-3" aria-label={`${site.name} — home`}>
      <span class="logo-mask h-9 w-9 shrink-0 transition-transform duration-700 group-hover:rotate-180" aria-hidden="true"></span>
      <span class="font-display text-[1.15rem] font-bold leading-none tracking-tight">
        Reliant<span class="text-brand-deep">&nbsp;Construction</span>
      </span>
    </a>

    <nav class="hidden items-center gap-8 lg:flex" aria-label="Primary">
      {
        nav.map((item) => (
          <a
            href={item.href}
            aria-current={path === item.href ? 'page' : undefined}
            class:list={[
              'nav-link font-mono text-[0.78rem] font-medium uppercase tracking-[0.14em] transition-colors duration-300',
              path === item.href ? 'text-brand-deep' : 'text-ink-700 hover:text-ink-900',
            ]}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="hidden items-center gap-6 lg:flex">
      <a
        href={site.solarUrl}
        target="_blank"
        rel="noopener"
        class="nav-link font-mono text-[0.78rem] font-medium uppercase tracking-[0.14em] text-[--solar] transition-opacity duration-300 hover:opacity-80"
      >
        Reliant Solar&nbsp;↗
      </a>
      <span class="h-5 w-px bg-ink-900/15" aria-hidden="true"></span>
      <a href="/contact#free-estimate" class="btn-primary !px-5 !py-2.5 text-[0.72rem]">Free estimate</a>
    </div>

    <button
      id="nav-toggle"
      class="flex h-11 w-11 flex-col items-center justify-center gap-[5px] lg:hidden"
      aria-label="Toggle menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span class="nav-line h-[2px] w-6 bg-ink-900 transition-transform duration-300 ease-out"></span>
      <span class="nav-line h-[2px] w-6 bg-ink-900 transition-opacity duration-300 ease-out"></span>
      <span class="nav-line h-[2px] w-6 bg-ink-900 transition-transform duration-300 ease-out"></span>
    </button>
  </div>

  <div id="mobile-menu" class="menu-shell relative lg:!hidden">
    <div class="overflow-hidden">
      <nav class="mx-auto flex max-w-site flex-col border-t border-ink-900/10 bg-paper-soft px-5 pb-5 pt-1" aria-label="Mobile">
        {
          nav.map((item, i) => (
            <a
              href={item.href}
              class="menu-item border-b border-ink-900/[0.07] py-3.5 font-mono text-[0.85rem] font-medium uppercase tracking-[0.14em] text-ink-900"
              style={`--i: ${i}`}
            >
              {item.label}
            </a>
          ))
        }
        <a
          href={site.solarUrl}
          target="_blank"
          rel="noopener"
          class="menu-item border-b border-ink-900/[0.07] py-3.5 font-mono text-[0.85rem] font-medium uppercase tracking-[0.14em] text-[--solar]"
          style={`--i: ${nav.length}`}
        >
          Reliant Solar ↗
        </a>
        <div class="menu-item flex flex-col gap-3 pt-5" style={`--i: ${nav.length + 1}`}>
          <a href={site.phoneHref} class="btn-ghost justify-center">{site.phoneDisplay}</a>
          <a href="/contact#free-estimate" class="btn-primary justify-center">Free estimate</a>
        </div>
      </nav>
    </div>
  </div>
</header>

<style>
  /* Scrolled backdrop fades instead of snapping */
  .nav-bg {
    transition: opacity 0.45s cubic-bezier(0.22, 1, 0.36, 1);
  }
  #site-nav[data-scrolled='true'] .nav-bg,
  #site-nav[data-open='true'] .nav-bg {
    opacity: 1;
  }

  /* Entrance: slide down softly on load */
  @media (prefers-reduced-motion: no-preference) {
    .nav-enter {
      animation: navIn 0.65s cubic-bezier(0.22, 1, 0.36, 1) both;
    }
  }
  @keyframes navIn {
    from {
      transform: translateY(-16px);
      opacity: 0;
    }
    to {
      transform: none;
      opacity: 1;
    }
  }

  /* Desktop link underline: grows from the left on hover */
  .nav-link {
    position: relative;
  }
  .nav-link::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -6px;
    height: 1.5px;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .nav-link:hover::after,
  .nav-link[aria-current='page']::after {
    transform: scaleX(1);
  }

  /* Mobile menu: smooth expand/collapse via grid rows */
  .menu-shell {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.45s cubic-bezier(0.22, 1, 0.36, 1);
  }
  #site-nav[data-open='true'] .menu-shell {
    grid-template-rows: 1fr;
  }

  /* Menu items cascade in once the shell opens */
  .menu-item {
    opacity: 0;
    transform: translateY(8px);
    transition:
      opacity 0.35s ease,
      transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }
  #site-nav[data-open='true'] .menu-item {
    opacity: 1;
    transform: none;
    transition-delay: calc(0.08s + var(--i, 0) * 0.045s);
  }

  /* Hamburger morphs into an X */
  #nav-toggle[aria-expanded='true'] .nav-line:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  #nav-toggle[aria-expanded='true'] .nav-line:nth-child(2) {
    opacity: 0;
  }
  #nav-toggle[aria-expanded='true'] .nav-line:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  @media (prefers-reduced-motion: reduce) {
    .nav-bg,
    .menu-shell,
    .menu-item,
    .nav-link::after {
      transition: none;
    }
    .menu-item {
      opacity: 1;
      transform: none;
    }
  }
</style>

<script>
  const header = document.getElementById('site-nav');
  const toggle = document.getElementById('nav-toggle');

  // rAF-throttled scroll state — writes only when the state actually flips
  let ticking = false;
  let scrolled = false;
  const update = () => {
    ticking = false;
    const next = window.scrollY > 24;
    if (next !== scrolled) {
      scrolled = next;
      header?.setAttribute('data-scrolled', String(scrolled));
    }
  };
  update();
  window.addEventListener(
    'scroll',
    () => {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(update);
      }
    },
    { passive: true }
  );

  toggle?.addEventListener('click', () => {
    const open = header?.getAttribute('data-open') !== 'true';
    header?.setAttribute('data-open', String(open));
    toggle.setAttribute('aria-expanded', String(open));
  });
</script>

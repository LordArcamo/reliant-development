---
const reasons = [
  {
    title: 'Fixed pricing, in writing',
    body: 'The number on the proposal is the number on the final invoice. Any change — a scope you add or a condition demo uncovers — is priced and signed by you before work continues.',
  },
  {
    title: 'In-house crews',
    body: 'Framing, roofing, siding, and finish work are self-performed by W-2 crews. You will see the same faces on site from demo to punch list.',
  },
  {
    title: 'A daily photo log',
    body: 'Every day on site ends with photos in your inbox. Away for the week? You still know exactly what got built.',
  },
  {
    title: 'One family of companies',
    body: 'Roof, structure, and solar under one accountable family. When Reliant Construction and Reliant Solar share a site, there is one schedule and zero finger-pointing.',
  },
];

// TODO(client): if a one-year return inspection is a real service, restore it here
// and add it to the process + FAQ so it's consistent site-wide.
const warranties = [
  { qualifier: '', years: '10-yr', label: 'Workmanship warranty', note: 'Our labor, in writing, transferable' },
  { qualifier: 'Up to', years: '25-yr', label: 'Material warranties', note: 'Manufacturer-backed where offered' },
  { qualifier: '', years: 'Day 1', label: 'Warranty in writing', note: 'Handed over at the final walkthrough' },
];
---

<section id="why-reliant" class="atmo-dark bg-[--band] text-ink-900">
  <div class="mx-auto max-w-site px-5 py-20 lg:px-8 lg:py-28">
    <div class="grid gap-14 lg:grid-cols-[1.1fr_0.9fr]">
      <div>
        <p class="eyebrow !text-brand-bright">Why Reliant</p>
        <h2 class="display mt-4 text-[clamp(1.9rem,4vw,2.9rem)] text-ink-900">
          We don't compete on cheap.<br />
          <span class="text-brand-bright">We compete on still-standing-in-2050.</span>
        </h2>
        <div class="mt-10 grid gap-8 sm:grid-cols-2">
          {
            reasons.map((r) => (
              <div class="border-l-2 border-brand pl-5">
                <h3 class="font-display text-[1.1rem] font-bold text-ink-900">{r.title}</h3>
                <p class="mt-2 text-[0.9rem] leading-relaxed text-ink-700">{r.body}</p>
              </div>
            ))
          }
        </div>
      </div>
      <div class="lg:pl-6">
        <p class="font-mono text-[0.7rem] font-semibold uppercase tracking-[0.2em] text-ink-500">The warranty stack</p>
        <div class="mt-5 space-y-4">
          {
            warranties.map((w) => (
              <div class="flex items-center border border-ink-900/15 bg-ink-900/[0.04] p-5">
                <span class="w-[4.4rem] shrink-0 sm:w-[5rem]">
                  <span
                    class:list={[
                      'block font-mono text-[0.58rem] uppercase tracking-[0.18em] text-ink-500',
                      !w.qualifier && 'invisible',
                    ]}
                  >
                    {w.qualifier || 'up to'}
                  </span>
                  <span class="mt-0.5 block whitespace-nowrap font-display text-[1.4rem] font-bold leading-none text-brand-bright [font-variant-numeric:tabular-nums] sm:text-[1.6rem]">
                    {w.years}
                  </span>
                </span>
                <div class="border-l border-ink-900/10 pl-4 sm:pl-5">
                  <p class="font-mono text-[0.7rem] font-semibold uppercase tracking-[0.16em] text-ink-900">{w.label}</p>
                  <p class="mt-0.5 text-[0.85rem] text-ink-500">{w.note}</p>
                </div>
              </div>
            ))
          }
        </div>
        <a href="/about" class="btn-light mt-8">More about the company</a>
      </div>
    </div>
  </div>
</section>

---
const tracks = [
  {
    href: '/residential',
    eyebrow: 'For homeowners',
    title: 'Residential',
    body: 'Kitchens, baths, additions, roofing, decks, and whole-home remodels — with a fixed price and a start date locked before demo day.',
    items: ['Kitchens & baths', 'Additions & dormers', 'Roofing & siding', 'Whole-home remodels'],
  },
  {
    href: '/commercial',
    eyebrow: 'For owners & property managers',
    title: 'Commercial',
    body: 'Tenant fit-outs, ground-up light commercial, roofing, and facility programs delivered on landlord schedules across NJ, NY & PA.',
    items: ['Tenant fit-outs', 'Ground-up construction', 'Commercial roofing', 'Facility maintenance'],
  },
];
---

<section id="services" class="border-y border-ink-900/10 bg-paper-soft">
  <div class="mx-auto max-w-site px-5 py-20 lg:px-8 lg:py-28">
    <p class="eyebrow">What we build</p>
    <h2 class="display mt-4 max-w-2xl text-[clamp(1.9rem,4vw,2.9rem)]">Two doors, same standard.</h2>
    <div class="mt-12 grid gap-6 lg:grid-cols-2">
      {
        tracks.map((t) => (
          <a
            href={t.href}
            class="group relative block border border-ink-900/15 bg-paper p-8 card-hover lg:p-10"
          >
            <div class="absolute inset-x-0 top-0 h-[3px] bg-brand opacity-0 transition-opacity duration-300 group-hover:opacity-100" />
            <p class="eyebrow">{t.eyebrow}</p>
            <h3 class="display mt-3 text-[2rem]">{t.title}</h3>
            <p class="mt-3 max-w-md text-[0.98rem] leading-relaxed text-ink-700">{t.body}</p>
            <ul class="mt-6 grid grid-cols-2 gap-x-4 gap-y-2">
              {t.items.map((item) => (
                <li class="flex items-center gap-2 text-[0.88rem] text-ink-700">
                  <span class="h-1.5 w-1.5 shrink-0 bg-brand" />
                  {item}
                </li>
              ))}
            </ul>
            <p class="mt-8 font-mono text-[0.75rem] font-semibold uppercase tracking-[0.16em] text-brand-deep transition-transform duration-300 group-hover:translate-x-1.5">
              Explore {t.title.toLowerCase()} →
            </p>
          </a>
        ))
      }
    </div>
  </div>
</section>

---
import { faqs } from '../data/site';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<section id="faq" class="mx-auto max-w-site px-5 py-20 lg:px-8 lg:py-28">
  <div class="grid gap-10 lg:grid-cols-[0.8fr_1.2fr]">
    <div>
      <p class="eyebrow">Straight answers</p>
      <h2 class="display mt-4 text-[clamp(1.9rem,4vw,2.9rem)]">Asked before every job.</h2>
      <p class="mt-4 max-w-sm text-[0.98rem] leading-relaxed text-ink-700">
        If your question isn't here, call
        <a href="tel:+18772011955" class="font-semibold text-brand-deep hover:underline">1·877·201·1955</a>
        — a project lead answers, not a call center.
      </p>
    </div>
    <div class="divide-y divide-ink-900/10 border-y border-ink-900/10">
      {
        faqs.map((f) => (
          <details class="group py-5">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-display text-[1.1rem] font-bold [&::-webkit-details-marker]:hidden">
              {f.q}
              <span class="flex h-8 w-8 shrink-0 items-center justify-center border border-ink-900/25 font-mono text-brand-deep transition-transform duration-200 group-open:rotate-45">
                +
              </span>
            </summary>
            <p class="mt-3 max-w-2xl text-[0.95rem] leading-relaxed text-ink-700">{f.a}</p>
          </details>
        ))
      }
    </div>
  </div>
</section>

<script type="application/ld+json" set:html={JSON.stringify(schema)} />

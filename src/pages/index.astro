---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero';
import StatStrip from '../components/StatStrip';
import Pillars from '../components/Pillars.astro';
import ServicesSplit from '../components/ServicesSplit.astro';
import RecentWork from '../components/RecentWork.astro';
import Process from '../components/Process.astro';
import WhyReliant from '../components/WhyReliant.astro';
import SolarBand from '../components/SolarBand.astro';
import FAQ from '../components/FAQ.astro';
import PageCTA from '../components/PageCTA.astro';
import { stats } from '../data/site';
---

<Base
  title="Reliant Construction — General Contractor in NJ, NY & PA"
  description="General contractor for residential and commercial projects in NJ, NY & PA. In-house crews, fixed pricing, and a 10-year workmanship warranty. Free estimates."
>
  <section class="atmo border-b border-ink-900/10" data-no-reveal>
    <Hero client:load />
  </section>

  <section data-no-reveal>
    <StatStrip client:visible stats={stats} />
  </section>

  <Pillars />
  <ServicesSplit />
  <RecentWork />
  <Process />
  <WhyReliant />
  <SolarBand />
  <FAQ />
  <PageCTA />
</Base>

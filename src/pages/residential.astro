---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import ServiceGrid from '../components/ServiceGrid.astro';
import Process from '../components/Process.astro';
import SolarBand from '../components/SolarBand.astro';
import PageCTA from '../components/PageCTA.astro';
import { residentialServices } from '../data/services';

const promises = [
  { title: 'A start date locked before demo', body: 'Materials ordered and crews scheduled before demo day — not after.' },
  { title: 'Your house, respected', body: 'Dust barriers, floor protection, daily cleanup, magnet-swept driveway.' },
  { title: 'One project lead', body: 'A single phone number that answers, from first walkthrough to final punch item.' },
  { title: 'No invoice surprises', body: 'Fixed price in writing; change orders signed by you before work continues.' },
];
---

<Base
  title="Residential Remodeling in NJ, NY & PA | Reliant Construction"
  description="Kitchens, baths, additions, roofing, decks, and whole-home remodels in NJ, NY & PA. Fixed pricing, in-house crews, 10-year workmanship warranty. Free estimates."
>
  <PageHero
    image="/images/heroes/hero-residential.jpg"
    imageAlt="Modern white two-story home with landscaped front yard"
    eyebrow="Residential"
    title={`Your home, treated like <span class="text-brand-deep">our name is on it.</span>`}
    lede="Because it is. From a one-week bathroom refresh to a down-to-the-studs remodel, you get a fixed price, an in-house crew, a daily photo log, and a 10-year workmanship warranty — the same paper trail we bring to our commercial fit-outs and ground-up builds."
  />

  <ServiceGrid
    eyebrow="Residential services"
    heading={`Everything between the footing <span class="text-brand-deep">and the ridge cap.</span>`}
    services={residentialServices}
  />

  <section class="border-y border-ink-900/10 bg-paper-soft">
    <div class="mx-auto max-w-site px-5 py-20 lg:px-8 lg:py-24">
      <p class="eyebrow">The homeowner promise</p>
      <h2 class="display mt-4 max-w-2xl text-[clamp(1.8rem,3.8vw,2.7rem)]">
        Living in the house while we work on it? <span class="text-brand-deep">We plan for that.</span>
      </h2>
      <div class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
        {
          promises.map((p) => (
            <div class="border-t-2 border-brand pt-5">
              <h3 class="font-display text-[1.1rem] font-bold">{p.title}</h3>
              <p class="mt-2 text-[0.9rem] leading-relaxed text-ink-700">{p.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <Process />
  <SolarBand />
  <PageCTA
    heading="Get a free residential estimate."
    sub="Tell us about the project — we'll schedule a walkthrough within days and hand you a fixed-price proposal within 24 hours of the walkthrough."
  />
</Base>

---
import Base from '../layouts/Base.astro';
---

<Base title="Page not found — Reliant Construction" noindex>
  <section class="blueprint" data-no-reveal>
    <div class="mx-auto flex max-w-site flex-col items-start px-5 pb-24 pt-40 lg:px-8">
      <p class="eyebrow">Error 404</p>
      <h1 class="display mt-4 max-w-2xl text-[clamp(2.2rem,5vw,3.6rem)]">
        This page isn't on the drawings.
      </h1>
      <p class="mt-5 max-w-md text-[1rem] leading-relaxed text-ink-700">
        The address may have changed, or the link was mistyped. Everything we build is
        reachable from the home page.
      </p>
      <div class="mt-8 flex flex-wrap gap-4">
        <a href="/" class="btn-primary">Back to home</a>
        <a href="/contact" class="btn-ghost">Contact us</a>
      </div>
    </div>
  </section>
</Base>

---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import ServiceGrid from '../components/ServiceGrid.astro';
import SolarBand from '../components/SolarBand.astro';
import PageCTA from '../components/PageCTA.astro';
import { commercialServices } from '../data/services';

const capabilities = [
  { k: 'Delivery', v: 'Design-build · GC · CM' },
  { k: 'Schedules', v: 'After-hours & phased occupancy' },
  { k: 'Compliance', v: 'Full COI with every proposal' },
  { k: 'Portfolios', v: 'Multi-site programs, NJ · NY · PA' },
];

const clients = [
  {
    title: 'Property managers',
    body: 'Unit turns, common-area upgrades, capital projects, and a priority line for emergency repairs. One vendor file, every trade.',
  },
  {
    title: 'Business owners',
    body: 'Fit-outs and expansions built around your operating hours — open-for-business dates in the contract, not in the sales pitch.',
  },
  {
    title: 'Developers & landlords',
    body: 'White-box packages, tenant improvement allowances, and ground-up light commercial with sitework coordinated under one contract.',
  },
];
---

<Base
  title="Commercial Contractor in NJ, NY & PA | Reliant Construction"
  description="Tenant fit-outs, ground-up light commercial, roofing, concrete, and facility maintenance in NJ, NY & PA. In-house crews, landlord-ready schedules, full COI."
>
  <PageHero
    image="/images/heroes/hero-commercial.jpg"
    imageAlt="Multi-story concrete structure under construction with formwork shoring"
    eyebrow="Commercial"
    title={`Delivered on schedule, because <span class="text-brand-deep">your lease doesn't wait.</span>`}
    lede="Fit-outs, ground-up light commercial, roofing, and facility programs — self-performed by in-house crews, sequenced around your occupancy, and documented like the EPC contractor we grew out of."
  />

  <ServiceGrid
    eyebrow="Commercial services"
    heading={`From white box <span class="text-brand-deep">to open for business.</span>`}
    services={commercialServices}
  />

  <section class="blueprint-dark bg-[--band] text-ink-900">
    <div class="mx-auto max-w-site px-5 py-20 lg:px-8 lg:py-24">
      <div class="grid gap-12 lg:grid-cols-[1fr_1fr]">
        <div>
          <p class="eyebrow !text-brand-bright">Who we work with</p>
          <h2 class="display mt-4 text-[clamp(1.8rem,3.8vw,2.7rem)] text-ink-900">
            Built for people who <span class="text-brand-bright">answer for the budget and the schedule.</span>
          </h2>
          <p class="mt-5 max-w-md text-[0.98rem] leading-relaxed text-ink-700">
            Commercial work is a schedule business. Ours comes with a critical path, weekly
            reporting, and a project lead whose phone actually rings through.
          </p>
          <div class="mt-9 grid grid-cols-2 gap-px border border-ink-900/15 bg-ink-900/15">
            {
              capabilities.map((c) => (
                <div class="bg-[--band] p-5">
                  <p class="font-mono text-[0.62rem] font-semibold uppercase tracking-[0.2em] text-ink-500">{c.k}</p>
                  <p class="mt-1.5 text-[0.9rem] font-semibold text-ink-900">{c.v}</p>
                </div>
              ))
            }
          </div>
        </div>
        <div class="space-y-5 lg:pt-12">
          {
            clients.map((c) => (
              <div class="border border-ink-900/15 bg-ink-900/[0.04] p-6">
                <h3 class="font-display text-[1.2rem] font-bold text-brand-bright">{c.title}</h3>
                <p class="mt-2 text-[0.92rem] leading-relaxed text-ink-700">{c.body}</p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <SolarBand />
  <PageCTA
    formName="commercial-assessment"
    heading="Get a free commercial estimate."
    sub="Send the basics — property type, square footage, timeline — and a project lead will walk the site and come back with a scoped proposal."
  />
</Base>
